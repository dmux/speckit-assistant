{
  "name": "speckit-assistant",
  "version": "0.4.0",
  "description": "Visual orchestrator for Spec-Driven Development (SDD) — Next.js, ReactFlow and Hexagonal Architecture",
  "main": "dist/index.js",
  "bin": {
    "speckit-assistant": "./bin/bin/cli.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && tsc -p tsconfig.bin.json",
    "start": "next start",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "bin",
    ".next",
    "next.config.mjs",
    "extensions"
  ],
  "keywords": [
    "sdd",
    "speckit",
    "nextjs",
    "reactflow",
    "hexagonal-architecture"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmux/speckit-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/dmux/speckit-assistant/issues"
  },
  "homepage": "https://github.com/dmux/speckit-assistant#readme",
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.3.5",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "js-yaml": "^4.2.0",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "node-pty": "^1.1.0",
    "open": "^10.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-syntax-highlighter": "^16.1.1",
    "smol-toml": "^1.6.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-force": "^3.0.10",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.9",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
